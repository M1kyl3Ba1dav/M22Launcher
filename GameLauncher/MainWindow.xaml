<Window x:Class="GameLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game Launcher"
        Height="700"
        Width="1100"
        Background="#101010">

    <Grid>

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0f0f0f" Offset="0"/>
                <GradientStop Color="#1a1a1a" Offset="0.4"/>
                <GradientStop Color="#202020" Offset="0.7"/>
                <GradientStop Color="#151515" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Background="#1f1f1f"
                Grid.Row="0"
                Padding="10"
                Opacity="0.95">

            <Grid>
                

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>


                <!-- SEARCH -->
                <TextBox x:Name="SearchBox"
                         Height="40"
                         Margin="5"
                         Background="#2d2d2d"
                         Foreground="White"
                         BorderThickness="0"
                         Padding="10"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         TextChanged="SearchBox_TextChanged"/>

                <!-- FILTER -->
                <ComboBox x:Name="FilterBox"
                          Grid.Column="1"
                          Height="40"
                          Margin="5"
                          Background="#2d2d2d"
                          Foreground="White"
                          BorderThickness="0"
                          SelectionChanged="FilterBox_SelectionChanged">

                    <ComboBoxItem Content="All" IsSelected="True"/>
                    <ComboBoxItem Content="Steam"/>
                    <ComboBoxItem Content="Epic"/>
                    <ComboBoxItem Content="Riot"/>
                    <ComboBoxItem Content="Blizzard"/>
                    <ComboBoxItem Content="Xbox"/>

                </ComboBox>

                <!-- SORT -->
                <ComboBox x:Name="SortBox"
                          Grid.Column="2"
                          Height="40"
                          Margin="5"
                          Background="#2d2d2d"
                          Foreground="White"
                          BorderThickness="0"
                          SelectionChanged="SortBox_SelectionChanged">

                    <ComboBoxItem Content="A-Z" IsSelected="True"/>
                    <ComboBoxItem Content="Z-A"/>
                    <ComboBoxItem Content="Rating"/>
                    <ComboBoxItem Content="Release Date"/>

                </ComboBox>

                <!-- REFRESH -->
                <Button Grid.Column="3"
                        Content="Refresh"
                        Height="40"
                        Margin="5"
                        Background="#4CAF50"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="RefreshLibrary_Click"/>

            </Grid>

        </Border>

        <!-- GAME GRID -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">

            <ItemsControl x:Name="GameList">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Margin="10"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>

                    <DataTemplate>

                        <Border Width="210"
                                Height="300"
                                Margin="12"
                                CornerRadius="12"
                                Background="#202020"
                                Cursor="Hand">

                            <Border.RenderTransform>
                                <ScaleTransform x:Name="scale"
                                                ScaleX="1"
                                                ScaleY="1"/>
                            </Border.RenderTransform>

                            <Border.Triggers>

                                <EventTrigger RoutedEvent="MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>

                                            <DoubleAnimation
                                                Storyboard.TargetName="scale"
                                                Storyboard.TargetProperty="ScaleX"
                                                To="1.06"
                                                Duration="0:0:0.15"/>

                                            <DoubleAnimation
                                                Storyboard.TargetName="scale"
                                                Storyboard.TargetProperty="ScaleY"
                                                To="1.06"
                                                Duration="0:0:0.15"/>

                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>

                                <EventTrigger RoutedEvent="MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>

                                            <DoubleAnimation
                                                Storyboard.TargetName="scale"
                                                Storyboard.TargetProperty="ScaleX"
                                                To="1"
                                                Duration="0:0:0.15"/>

                                            <DoubleAnimation
                                                Storyboard.TargetName="scale"
                                                Storyboard.TargetProperty="ScaleY"
                                                To="1"
                                                Duration="0:0:0.15"/>

                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>

                            </Border.Triggers>

                            <StackPanel>

                                <!-- COVER -->
                                <Image Source="{Binding ImagePath}"
                                       Height="150"
                                       Stretch="Fill"/>

                                <!-- NAME -->
                                <TextBlock Text="{Binding Name}"
                                           Foreground="White"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Margin="8"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>

                                <!-- GENRE -->
                                <TextBlock Text="{Binding Genre}"
                                           Foreground="#aaaaaa"
                                           FontSize="12"
                                           HorizontalAlignment="Center"/>

                                <!-- RELEASE -->
                                <TextBlock Text="{Binding ReleaseDate}"
                                           Foreground="#888"
                                           FontSize="11"
                                           HorizontalAlignment="Center"/>

                                <!-- RATING -->
                                <TextBlock Text="{Binding Rating}"
                                           Foreground="#FFD700"
                                           FontSize="12"
                                           HorizontalAlignment="Center"/>

                                <!-- PLAY -->
                                <Button Content="Play"
                                        Tag="{Binding ExecutablePath}"
                                        Margin="10,6"
                                        Height="32"
                                        Background="#3f51b5"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Click="PlayGame_Click"/>

                            </StackPanel>

                        </Border>

                    </DataTemplate>

                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </ScrollViewer>

    </Grid>

</Window>
