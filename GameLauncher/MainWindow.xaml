<Window x:Class="GameLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game Launcher"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#0D0B1F">

    <!-- MAIN LAYOUT -->
    <Grid>

        <!-- 🌌 PURPLE GRADIENT BACKGROUND -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#120A2A" Offset="0"/>
                <GradientStop Color="#1E144A" Offset="0.5"/>
                <GradientStop Color="#2C1F6B" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="75"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= TOP BAR ================= -->
        <Border Grid.Row="0"
                Margin="12,12,12,0"
                Padding="10"
                CornerRadius="18">

            <!-- GLASS EFFECT -->
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#55FFFFFF" Offset="0"/>
                    <GradientStop Color="#22FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                                  ShadowDepth="0"
                                  Opacity="0.35"/>
            </Border.Effect>

            <!-- TOP GRID -->
            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>

                <!-- SEARCH -->
                <TextBox x:Name="SearchBox"
                         Height="40"
                         Margin="5"
                         Background="#33FFFFFF"
                         Foreground="White"
                         BorderThickness="0"
                         Padding="10"
                         FontSize="14"
                         VerticalContentAlignment="Center"
                         TextChanged="SearchBox_TextChanged"/>

                <!-- FILTER -->
                <ComboBox x:Name="FilterBox"
                          Grid.Column="1"
                          Height="40"
                          Margin="5"
                          Background="#33FFFFFF"
                          Foreground="Black"
                          BorderThickness="0"
                          SelectionChanged="FilterBox_SelectionChanged">

                    <ComboBoxItem Content="All" IsSelected="True"/>
                    <ComboBoxItem Content="Steam"/>
                    <ComboBoxItem Content="Epic"/>
                    <ComboBoxItem Content="Riot"/>
                    <ComboBoxItem Content="Blizzard"/>
                    <ComboBoxItem Content="Xbox"/>

                </ComboBox>

                <!-- SORT -->
                <ComboBox x:Name="SortBox"
                          Grid.Column="2"
                          Height="40"
                          Margin="5"
                          Background="#33FFFFFF"
                          Foreground="Black"
                          BorderThickness="0"
                          SelectionChanged="SortBox_SelectionChanged">

                    <ComboBoxItem Content="A-Z" IsSelected="True"/>
                    <ComboBoxItem Content="Z-A"/>
                    <ComboBoxItem Content="Rating"/>
                    <ComboBoxItem Content="Release Date"/>

                </ComboBox>

                <!-- REFRESH -->
                <Button Grid.Column="3"
                        Content="Refresh"
                        Height="40"
                        Margin="5"
                        Background="#7C5CFF"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="RefreshLibrary_Click"/>

            </Grid>

        </Border>

        <!-- ================= GAME GRID ================= -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">

            <ItemsControl x:Name="GameList">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Margin="15"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>

                    <DataTemplate>

                        <Border Width="220"
                                Height="310"
                                Margin="12"
                                CornerRadius="16"
                                Cursor="Hand">

                            <!-- GLASS CARD -->
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#33FFFFFF" Offset="0"/>
                                    <GradientStop Color="#11FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15"
                                                  ShadowDepth="4"
                                                  Opacity="0.4"/>
                            </Border.Effect>

                            <Border.RenderTransform>
                                <ScaleTransform x:Name="scale"
                                                ScaleX="1"
                                                ScaleY="1"/>
                            </Border.RenderTransform>

                            <Border.Triggers>

                                <!-- HOVER ANIMATION -->
                                <EventTrigger RoutedEvent="MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1.06"
                                                             Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="scale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1.06"
                                                             Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>

                                <EventTrigger RoutedEvent="MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="scale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1"
                                                             Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="scale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1"
                                                             Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>

                            </Border.Triggers>

                            <!-- CARD CONTENT -->
                            <StackPanel>

                                <!-- COVER -->
                                <Image Source="{Binding ImagePath}"
                                       Height="150"
                                       Stretch="Fill"/>

                                <!-- NAME -->
                                <TextBlock Text="{Binding Name}"
                                           Foreground="White"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Margin="8"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>

                                <!-- GENRE -->
                                <TextBlock Text="{Binding Genre}"
                                           Foreground="#CCCCCC"
                                           FontSize="12"
                                           HorizontalAlignment="Center"/>

                                <!-- RELEASE -->
                                <TextBlock Text="{Binding ReleaseDate}"
                                           Foreground="#AAAAAA"
                                           FontSize="11"
                                           HorizontalAlignment="Center"/>

                                <!-- RATING -->
                                <TextBlock Text="{Binding Rating}"
                                           Foreground="#FFD700"
                                           FontSize="12"
                                           HorizontalAlignment="Center"/>

                                <!-- PLAY BUTTON -->
                                <Button Content="Play"
                                        Tag="{Binding ExecutablePath}"
                                        Margin="10,8"
                                        Height="34"
                                        Background="#7C5CFF"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Click="PlayGame_Click"/>

                            </StackPanel>

                        </Border>

                    </DataTemplate>

                </ItemsControl.ItemTemplate>

            </ItemsControl>

        </ScrollViewer>

    </Grid>

</Window>
